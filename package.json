{
  "name": "@sirrlock/n8n-nodes-sirr",
  "version": "1.0.0",
  "description": "n8n community node for Sirr — ephemeral secret management",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "sirr",
    "secrets",
    "ephemeral"
  ],
  "license": "MIT",
  "author": {
    "name": "Sirr Security Inc.",
    "email": "oss@sirrlock.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sirrlock/n8n-nodes-sirr.git"
  },
  "main": "dist/nodes/Sirr/Sirr.node.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest --testPathIgnorePatterns='e2e'",
    "test:e2e": "jest --testMatch='**/nodes/**/*.e2e.test.ts'",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/SirrApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Sirr/Sirr.node.js"
    ]
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/nodes/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    }
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "n8n-workflow": "^1.0.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "n8n-workflow": "^1.0.0"
  }
}
